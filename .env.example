# DJANGO_SECRET_KEY=   # production only; не залишайте порожнім рядком у .env

DJANGO_SETTINGS_MODULE=config.settings

ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://127.0.0.1:8000
